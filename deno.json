{
  "name": "@canac/git-cleanup",
  "version": "0.1.0",
  "license": "MIT",
  "exports": "./main.ts",
  "tasks": {
    "dev": "deno run --allow-env --allow-read --allow-run=git --watch main.ts",
    "test": "deno test --permission-set",
    "test-coverage": "deno task test --coverage --clean",
    "test-e2e": "deno test --permission-set=e2e e2e/e2e_test.ts",
    "test-e2e-coverage": "deno task test-e2e --coverage --clean"
  },
  "permissions": {
    "e2e": {
      "env": true,
      "read": true,
      "run": ["git"],
      "write": true
    }
  },
  "imports": {
    "@david/dax": "jsr:@david/dax@^0.43",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/collections": "jsr:@std/collections@^1",
    "@std/expect": "jsr:@std/expect@^1",
    "@std/fmt": "jsr:@std/fmt@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/testing": "jsr:@std/testing@^1"
  },
  "fmt": {
    "lineWidth": 100
  },
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "*.ts"
    ],
    "exclude": [
      "*_test.ts"
    ]
  },
  "test": {
    "include": ["*_test.ts"],
    "permissions": {
      "read": true
    }
  },
  "compilerOptions": {
    "noUncheckedIndexedAccess": true
  }
}
